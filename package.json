{
  "name": "codie",
  "displayName": "Codie Minimal",
  "description": "Minimal VS Code extension with a Webview View",
  "version": "0.0.1",
  "publisher": "mrtrilb",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codie-activitybar",
          "title": "Codie",
          "icon": "media/icon-activity-bar.svg"
        }
      ]
    },
    "views": {
      "codie-activitybar": [
        {
          "id": "codie-chat-view",
          "name": "Codie Chat",
          "type": "webview",
          "icon": "media/icon-activity-bar.svg"
        },
        {
          "id": "codie-data-view",
          "name": "Codie Data",
          "icon": "media/icon-activity-bar.svg"
        }
      ]
    },
    "commands": [
      
      {
        "command": "codie.openChat",
        "title": "Open Codie Chat"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/vscode": "^1.103.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "2.3.0",
    "eslint": "^9.32.0",
    "mocha": "10.2.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.1"
  },
  "scripts": {
    "compile": "webpack --mode production",
    "watch-tests": "mocha --require ts-node/register --watch \"test/**/*.ts\" --ignore \"context/**\"",
    "test": "vscode-test run --extensionDevelopmentPath=. --extensionTestsPath=./test/index"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.39"
  }
}

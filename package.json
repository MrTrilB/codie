{
  "name": "codie",
  "displayName": "Codie Minimal",
  "description": "Minimal VS Code extension with a Webview View",
  "version": "0.0.1",
  "publisher": "mrtrilb",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",

  "activationEvents": ["onView:codie-chat-view"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codie-activitybar",
          "title": "Codie",
          "icon": "media/icon-activity-bar.svg"
        }
      ]
    },
    "views": {
      "codie-activitybar": [
        {
          "id": "codie-chat-view",
          "name": "Codie Chat",
          "type": "webview"
        },
        {
          "id": "codie-data-view",
          "name": "Codie Data"
        }
      ]
    },
    "commands": [
      {
        "command": "codie.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "codie.openChat",
        "title": "Open Codie Chat"
      }
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.32.0",
    "typescript": "^5.9.2",
    "ts-loader": "^9.5.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "2.3.0",
    "mocha": "10.2.0"
  }
  ,
  "scripts": {
    "compile": "webpack --mode production"
  }
}

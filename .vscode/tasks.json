{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$ts-webpack-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      }
    },
    {
      "label": "tsc: watch - tsconfig.json",
      "type": "shell",
      "command": "npx tsc --watch --preserveWatchOutput",
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "typescript",
          "pattern": {
            "regexp": ".*",
            "file": 1,
            "location": 2,
            "message": 3
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "[Ww]atching.*file changes"
          }
        }
      ],
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      },
      "group": "build"
    },

  ]
}

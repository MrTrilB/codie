{
  // A launch configuration that compiles the extension and then opens it inside a new window

  "version": "0.2.0", // Use IntelliSense to learn about possible attributes.

  "configurations": [ // Hover to view descriptions of existing attributes.

    { // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387

      "name": "Run Extension",

      "type": "extensionHost",

      "request": "launch",

      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],

      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],

      "preLaunchTask": "npm: watch"
    },
    {
      "name": "Extension Tests",

      "type": "extensionHost",

      "request": "launch",

      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],

      "outFiles": [
        "${workspaceFolder}/dist/extension.js",
        "${workspaceFolder}/out/test/**/*.js"
      ],

  "preLaunchTask": "tasks: watch-tests"
    },
    {
      "name": "Run Extension with Tests (No Extensions)",

      "type": "extensionHost",

      "request": "launch",

      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions"
      ],

      "outFiles": [
        "${workspaceFolder}/dist/extension.js",
        "${workspaceFolder}/out/test/**/*.js"
      ],

  "preLaunchTask": "tasks: watch-tests"
    }
  ]
}
